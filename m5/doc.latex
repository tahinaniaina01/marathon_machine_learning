        grid=major,
        grid style={dashed, gray!30},
      ]
      \addplot[fill=zindi!70, draw=zindi] coordinates {
        (7 jours, 1.4)
        (90 jours, 3.0)
        (120 jours, 4.1)
      };
    \end{axis}
  \end{tikzpicture}
  \caption{Taux d'adoption (en \%) par fenêtre temporelle sur l'ensemble Train+Prior}
  \label{fig:class_imbalance}
\end{figure}

\textbf{Interprétation~:} Le déséquilibre est très prononcé, en particulier pour la cible à 7 jours (moins de 1.5\% de positifs). Cela signifie qu'un modèle naïf prédisant toujours 0 atteindrait une précision de plus de 98\%, ce qui serait trompeur. C'est pourquoi la métrique AUC-ROC, qui est indépendante du seuil de décision, est préférée.

