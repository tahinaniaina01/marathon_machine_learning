        y tick label style={font=\small},
      ]
      \addplot[fill=zindi!70, draw=zindi] coordinates {
        (12, has\_dairy\_topic)
        (15, has\_poultry\_topic)
        (28, n\_unique\_topics)
        (31, n\_sessions)
        (35, n\_topics)
        (40, month)
        (48, week\_of\_year)
        (54, day\_of\_week)
        (57, ward)
        (62, subcounty)
        (65, county)
